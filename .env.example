# ── Seguridad ────────────────────────────────────────────────────────────────
SECRET_KEY=demo

# ── Modo de depuración ────────────────────────────────────────────────────────
# True en desarrollo, False en producción
DEBUG=True

# ── Hosts permitidos (producción) ─────────────────────────────────────────────
# Separados por coma. Ejemplo: ALLOWED_HOSTS=unphu.edu.do,www.unphu.edu.do
ALLOWED_HOSTS=

# ── Correo (Gmail) ────────────────────────────────────────────────────────────
# Cambiar EMAIL_BACKEND a smtp para enviar correos reales.
# Dejar console para solo ver los correos en la terminal (desarrollo).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Tu cuenta de Gmail
EMAIL_HOST_USER=tu-correo@gmail.com

# Contraseña de aplicación de Google (NO tu contraseña de Gmail).
# Cómo obtenerla:
#   1. Ve a myaccount.google.com → Seguridad
#   2. Activa "Verificación en dos pasos" si no la tienes
#   3. Busca "Contraseñas de aplicaciones"
#   4. Crea una nueva con nombre "Django UNPHU Eventos"
#   5. Copia las 16 letras que te da Google y pégalas aquí (sin espacios)
EMAIL_HOST_PASSWORD=abcd efgh ijkl mnop

# Nombre y correo que verán los destinatarios en el campo "De:"
DEFAULT_FROM_EMAIL=UNPHU Eventos <no-reply@unphu.edu.do>
